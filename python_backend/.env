# =========================================
# AI API Keys Configuration
# =========================================

# The active AI provider. Options: 'gemini', 'openai', 'ollama'
AI_PROVIDER=gemini

# Google Gemini Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4-turbo

# Groq Settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Local Settings
APP_WORK_DIR=workspace

# =========================================
# Tech Stack Overview
# =========================================
# Frontend: React 18, Vite, Tailwind CSS, Axios
# Backend: Python 3, FastAPI, Uvicorn, ReportLab
# Build Tools: OpenRewrite, Maven, Gradle
# AI/ML: Google Gemini API, OpenAI API, Ollama (Local)
# RAG/Search: FAISS, SentenceTransformers, LangChain
